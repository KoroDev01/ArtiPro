import React, { useState, useEffect } from "react";
import { useParams } from "react-router-dom";
import api from "../../api";
import Header from "../../components/Header";

export default function JobDetails() {
  const { id } = useParams(); // On récupère l'ID depuis l'URL
  const [job, setJob] = useState(null);

  useEffect(() => {
    const fetchDetails = async () => {
      try {
        // Attention : Vérifie que cette route existe dans ton backend !
        const response = await api.get(`/posts/${id}`);
        setJob(response.data);
      } catch (error) {
        console.error("Erreur lors de la récupération du job", error);
      }
    };
    fetchDetails();
  }, [id]);

  if (!job)
    return <div className="pt-32 text-center">Chargement des détails...</div>;

  return (
    <div className="min-h-screen bg-gray-50">
      <Header />
      <main className="pt-28 pb-12 max-w-5xl mx-auto px-6">
        <div className="bg-white rounded-2xl shadow-sm p-8">
          <div className="flex justify-between items-start mb-6">
            <div>
              <span className="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full uppercase">
                {job.category?.name}
              </span>
              <h1 className="text-4xl font-bold mt-4 ">{job.title}</h1>
              <p className="text-gray-500 mt-2 mx-0 ">
                Posté le {new Date(job.createdAt).toLocaleDateString()}
              </p>
            </div>
            <div className="text-right">
              <p className="text-2xl font-bold text-blue-600">
                {job.budget} DZD
              </p>
              <p className="text-gray-400 text-sm">
                📍 {job.location || "Lieu non précisé"}
              </p>
            </div>
          </div>

          <div className="border-t border-b py-6 my-6">
            <h2 className="text-xl font-semibold mb-4 flex justify-center">
              Description du projet
            </h2>
            <p className="text-gray-700 leading-relaxed flex justify-center">
              {job.description}
            </p>
          </div>

          {/* Galerie photos */}
          {job.photos && job.photos.length > 0 && (
            <div className="mb-8">
              <h2 className="text-xl font-semibold mb-4 flex justify-center">
                Photos
              </h2>
              <div className="flex justify-center size-80 gap-4 ">
                {job.photos.map((photo, index) => (
                  <img
                    key={index}
                    src={`http://localhost:3000/images/posts/${photo}`}
                    alt={`Vue ${index + 1}`}
                    className="rounded-xl w-full h-64 object-cover border"
                  />
                ))}
              </div>
            </div>
          )}

          <div className="flex gap-4 justify-center">
            <button className="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition">
              Postuler à cette offre
            </button>
            <button className="border border-gray-300 px-8 py-3 rounded-xl font-bold hover:bg-gray-50 transition">
              Contacter le client
            </button>
          </div>
        </div>
      </main>
    </div>
  );
}
