import React, { useState } from "react";
import { useNavigate, Link } from "react-router-dom";
import { useAuth } from "../../context/AuthContext"; // Vérifie bien le chemin vers ton dossier context

export default function Register() {
  // 1. États pour stocker les saisies du formulaire
  const [formData, setFormData] = useState({
    username: "",
    email: "",
    password: "",
    confirmPassword: "",
  });
  const [error, setError] = useState("");

  // 2. On récupère 'register' du contexte et on le renomme 'registerUser'
  // pour éviter le conflit de nom avec le composant "Register"
  const { register: registerUser } = useAuth();
  const navigate = useNavigate();

  // 3. Mise à jour des états quand on tape dans les champs
  const handleChange = (e) => {
    setFormData({ ...formData, [e.target.name]: e.target.value });
  };

  // 4. Fonction déclenchée à la soumission du formulaire
  const handleSubmit = async (e) => {
    e.preventDefault();
    setError(""); // On réinitialise l'erreur à chaque tentative

    // Vérification simple du mot de passe
    if (formData.password !== formData.confirmPassword) {
      return setError("Les mots de passe ne correspondent pas");
    }

    try {
      // On appelle la fonction du contexte (qui utilise Axios)
      const result = await registerUser({
        username: formData.username,
        email: formData.email,
        password: formData.password,
      });

      if (result.success) {
        alert("Compte créé avec succès !");
        navigate("/Login"); // Redirection vers la page de connexion
      } else {
        // Affiche l'erreur renvoyée par le serveur (ex: "Email déjà pris")
        setError(result.message);
      }
    } catch (err) {
      setError("Une erreur inattendue est survenue", err);
    }
  };

  return (
    <div className="min-h-screen bg-gray-100 flex items-center justify-center p-4">
      <div className="bg-white flex w-full max-w-5xl h-[700px] rounded-3xl shadow-2xl overflow-hidden">
        {/* Section Gauche : Image décorative */}
        <div className="hidden md:flex w-1/2 bg-blue-600 items-center justify-center p-8">
          <img
            src="/src/assets/img/photo-1678803262992-d79d06dd5d96.jpeg"
            className="rounded-2xl shadow-lg h-full object-cover"
            alt="Artisanat"
          />
        </div>

        {/* Section Droite : Formulaire */}
        <div className="w-full md:w-1/2 flex flex-col justify-center p-12">
          <h2 className="text-3xl font-bold mb-2 text-gray-800">
            Rejoignez ArtiPro
          </h2>
          <p className="text-gray-500 mb-8">
            Créez votre compte artisan ou client
          </p>

          {/* Affichage de l'erreur si elle existe */}
          {error && (
            <div className="bg-red-100 text-red-600 p-3 rounded-lg mb-4 text-sm font-medium border border-red-200">
              ⚠️ {error}
            </div>
          )}

          <form onSubmit={handleSubmit} className="space-y-4">
            <div>
              <input
                type="text"
                name="username"
                placeholder="Nom complet"
                className="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition"
                onChange={handleChange}
                required
              />
            </div>
            <div>
              <input
                type="email"
                name="email"
                placeholder="Email professionnel"
                className="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition"
                onChange={handleChange}
                required
              />
            </div>
            <div>
              <input
                type="password"
                name="password"
                placeholder="Mot de passe"
                className="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition"
                onChange={handleChange}
                required
              />
            </div>
            <div>
              <input
                type="password"
                name="confirmPassword"
                placeholder="Confirmez le mot de passe"
                className="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition"
                onChange={handleChange}
                required
              />
            </div>

            <button
              type="submit"
              className="w-full bg-blue-600 text-white py-3 rounded-xl font-bold hover:bg-blue-700 transition duration-300 shadow-lg shadow-blue-100">
              Créer mon compte
            </button>
          </form>

          <p className="mt-6 text-center text-gray-600">
            Déjà inscrit ?{" "}
            <Link
              to="/Login"
              className="text-blue-600 font-bold hover:underline">
              Connectez-vous ici
            </Link>
          </p>
        </div>
      </div>
    </div>
  );
}
</file>

