{
  "include": ["src/**"],
  "ignore": {
    "patterns": [
      "node_modules/**",
      "dist/**",
      "build/**",
      "public/**",
      "src/assets/**",
      "**/*.jpg",
      "**/*.png",
      "**/*.jpeg",
      "**/*.svg",
      "**/*.ico",
      "**/*.gif",
      "**/*.mp4",
      "**/*.mp3",
      "**/*.pdf",
      "package-lock.json",
      "yarn.lock",
      "*.lock"
    ]
  }
}
