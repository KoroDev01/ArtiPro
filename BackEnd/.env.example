# MongoDB
MONGO_URI=mongodb://localhost:27017/ArtiPro

# Session (min. 32 caractères en production)
SESSION_SECRET=changez-moi-par-une-cle-aleatoire-de-64-caracteres-minimum

# Serveur
PORT=3000
NODE_ENV=development

# Frontend (liens email, CORS)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email Brevo — SMTP
EMAIL_USER=votre-login@smtp-brevo.com
EMAIL_PASS=votre-cle-smtp-xsmtpsib
EMAIL_FROM=contact@votre-domaine.com
CONTACT_EMAIL=contact@votre-domaine.com

# Email Brevo — API (recommandé sur Railway, plus fiable que SMTP)
# Brevo → SMTP & API → Clés API et MCP → Générer une clé
BREVO_API_KEY=xkeysib-votre-cle-api

# En local uniquement — affiche les codes dans le terminal
MAIL_DEV_LOG=true

# Cloudinary (recommandé en production sur Railway)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
