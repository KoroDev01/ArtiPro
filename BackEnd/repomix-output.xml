<file path="config/multer.config.js">
const multer = require("multer");
const path = require("path");
const fs = require("fs");

// Configuration du stockage
const storage = multer.diskStorage({
  destination: (req, file, cb) => {
    // On définit le chemin vers le dossier public
    const dir = path.join(__dirname, "../public/images/posts");

    // Sécurité : Si le dossier n'existe pas, on le crée automatiquement
    if (!fs.existsSync(dir)) {
      fs.mkdirSync(dir, { recursive: true });
    }

    cb(null, dir);
  },
  filename: (req, file, cb) => {
    // On génère un nom unique : TIMESTAMP-NOMORIGINAL.extension
    const uniqueSuffix = Date.now() + "-" + Math.round(Math.random() * 1e9);
    cb(null, uniqueSuffix + path.extname(file.originalname));
  },
});

// Filtre pour n'accepter que les images (Optionnel mais recommandé pour ton examen)
const fileFilter = (req, file, cb) => {
  if (file.mimetype.startsWith("image/")) {
    cb(null, true);
  } else {
    cb(new Error("Le fichier doit être une image !"), false);
  }
};

// Création de l'instance Multer
const upload = multer({
  storage: storage,
  limits: { fileSize: 1024 * 1024 * 5 }, // Limite à 5Mo par image
  fileFilter: fileFilter,
});

// --- CRUCIAL : EXPORTATION DIRECTE ---
module.exports = upload;
</file>

<file path="config/passport.config.js">
const passport = require("passport");
const { app } = require("../app");
const User = require("../database/models/user.model");
const localStrategy = require("passport-local").Strategy;
const { findUserPerEmail } = require("../queries/user.queries.js");

console.log("Initializing Passport.js configuration");

app.use(passport.initialize());
app.use(passport.session());

passport.serializeUser((user, done) => {
  done(null, user._id);
});

passport.deserializeUser(async (id, done) => {
  try {
    const user = await User.findById(id).exec();
    done(null, user);
  } catch (e) {
    done(e, null);
  }
});

passport.use(
  new localStrategy(
    { usernameField: "email" },
    async (email, password, done) => {
      try {
        const user = await findUserPerEmail(email);
        if (!user) {
          console.log("User not found with email:", email);
          return done(null, false, { message: "Incorrect email." });
        }
        const isMatch = await user.comparePassword(password);
        if (!isMatch) {
          return done(null, false, { message: "Incorrect password." });
        }
        return done(null, user);
      } catch (e) {
        return done(e);
      }
    },
  ),
);
