const Offer = require("../database/models/offer.model");
const Post = require("../database/models/post.model");

exports.offerCreate = async (req, res, next) => {
  try {
    const { post: postId, price, message } = req.body; // On extrait 'post' du JSON

    // 1. Sécurité : Vérifier si l'ID envoyé est un ID MongoDB valide
    if (!postId || postId.length !== 24) {
      return res.status(400).json({ message: "ID de post invalide" });
    }

    // 2. Recherche du post
    const post = await Post.findById(postId);

    if (!post) {
      return res
        .status(404)
        .json({ message: "Post not found dans la base de données" });
    }

    // 3. Création de l'offre
    const newOffer = new Offer({
      post: postId,
      pro: req.user._id, // L'ID du pro connecté
      price,
      message,
      status: "pending",
    });

    await newOffer.save();
    const newNotif = new Notification({
      user: post.author,
      message: "Vous avez reçu une nouvelle offre pour votre annonce !",
      link: `/posts/${post._id}`,
    });
    await newNotif.save();

    res.status(201).json({
      message: "Offre envoyée avec succès !",
      offer: newOffer,
    });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
};
exports.getOffersByPost = async (req, res) => {
  try {
    const offers = await Offer.find({
      post: req.params.postId,
    })
      .populate("pro", "firstName ratingAverage")
      .sort({ createdAt: -1 });

    res.json(offers);
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
};
exports.acceptOffer = async (req, res) => {
  try {
    const offer = await Offer.findById(req.params.offerId).populate("post");

    if (!offer) {
      return res.status(404).json({ message: "Offer not found" });
    }

    if (offer.client.toString() !== req.user._id.toString()) {
      return res.status(403).json({
        message: "You are not allowed to accept this offer",
      });
    }

    offer.status = "accepted";
    await offer.save();

    // Mettre le post en in_progress
    offer.post.status = "in_progress";
    await offer.post.save();

    res.json({ message: "Offer accepted", offer });
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
};

exports.acceptOffer = async (req, res) => {
  try {
    const offer = await Offer.findById(req.params.offerId);

    if (!offer) {
      return res.status(404).json({ message: "Offer not found" });
    }

    if (offer.client.toString() !== req.user._id.toString()) {
      return res.status(403).json({
        message: "You are not allowed to accept this offer",
      });
    }

    // 1️⃣ Accepter l'offre sélectionnée
    offer.status = "accepted";
    await offer.save();

    // 2️⃣ Rejeter toutes les autres offres du même post
    await Offer.updateMany(
      {
        post: offer.post,
        _id: { $ne: offer._id },
      },
      { status: "rejected" },
    );

    // 3️⃣ Mettre le post en in_progress
    await Post.findByIdAndUpdate(offer.post, {
      status: "in_progress",
    });

    res.json({
      message: "Offer accepted. Other offers rejected.",
      offer,
    });
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
}; 
exports.offerUpdateStatus = async (req, res, next) => {
  try {
    const { offerId } = req.params;
    const { status } = req.body; // Peut être 'accepted', 'rejected' ou 'pending' (pour annulation)

    // 1. Mise à jour de l'offre
    const offer = await Offer.findByIdAndUpdate(
      offerId,
      { status: status },
      { new: true },
    );

    if (!offer) {
      return res.status(404).json({ message: "Offre non trouvée" });
    }

    // 2. Logique métier pour l'annonce liée
    if (status === "accepted") {
      // Si on accepte, on ferme l'annonce
      await Post.findByIdAndUpdate(offer.post, { status: "closed" });
    } else if (status === "rejected" || status === "pending") {
      // Si le client rejette ou annule une acceptation précédente,
      // on vérifie s'il n'y a pas d'AUTRE offre acceptée sur ce post.
      // Si aucune autre offre n'est acceptée, on rouvre l'annonce.
      const otherAccepted = await Offer.findOne({
        post: offer.post,
        status: "accepted",
      });

      if (!otherAccepted) {
        await Post.findByIdAndUpdate(offer.post, { status: "open" });
      }
    }

    res.status(200).json({ message: `Statut mis à jour : ${status}`, offer });
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
};
