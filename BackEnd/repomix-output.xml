exports.createPost = async (req, res) => {
  try {
    const { title, description, category } = req.body;
    const fileNames = req.files ? req.files.map((f) => f.filename) : [];

    // 1. Création du Post
    const newPost = new Post({
      title,
      description,
      category,
      author: req.user._id,
      photos: fileNames,
    });

    const savedPost = await newPost.save();

    // 2. Création de la Notification
    const newNotification = new Notification({
      message: `Nouvelle mission disponible : ${title}`,
      post: savedPost._id,
      category: category, // On garde la catégorie pour l'afficher aux bons artisans
    });

    await newNotification.save();

    res.status(201).json({ savedPost, notification: "Alerte créée !" });
  } catch (e) {
    res.status(400).json({ error: e.message });
  }
};
exports.deletePost = async (req, res) => {
  try {
    const postId = req.params.id;

    // 1. Trouver le post pour récupérer les noms des fichiers photos
    const post = await Post.findById(postId);

    if (!post) {
      return res.status(404).json({ message: "Post non trouvé" });
    }

    // Sécurité : Seul l'auteur peut supprimer son post
    if (post.author.toString() !== req.user._id.toString()) {
      return res
        .status(403)
        .json({ message: "Vous n'avez pas l'autorisation" });
    }

    // 2. Supprimer les fichiers physiques du dossier public
    if (post.photos && post.photos.length > 0) {
      post.photos.forEach((filename) => {
        const filePath = path.join(
          process.cwd(),
          "public/images/posts",
          filename,
        );
        // On vérifie si le fichier existe avant de le supprimer
        if (fs.existsSync(filePath)) {
          fs.unlinkSync(filePath);
        }
      });
    }

    // 3. Supprimer le post de la base de données
    await Post.findByIdAndDelete(postId);
    await Notification.deleteMany({ post: postId });
    res.json({ message: "Post et photos supprimés avec succès" });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
};
exports.getPostById = async (req, res) => {
  try {
    const post = await Post.findById(req.params.id)
      .populate("category", "name")
      .populate("author", "firstName lastName email");
